{
  "name": "@civic-lens/utils",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "prebuild": "corepack pnpm --filter @civic-lens/types build",
    "build": "tsc -p tsconfig.json",
    "pretypecheck": "corepack pnpm --filter @civic-lens/types build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@civic-lens/types": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
