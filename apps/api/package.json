{
  "name": "@civic-lens/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "corepack pnpm --filter @civic-lens/types build && corepack pnpm --filter @civic-lens/utils build && corepack pnpm prisma:generate",
    "dev": "nest start --watch",
    "prebuild": "corepack pnpm --filter @civic-lens/types build && corepack pnpm --filter @civic-lens/utils build && corepack pnpm prisma:generate",
    "build": "nest build",
    "prelint": "corepack pnpm prisma:generate",
    "lint": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/main.js",
    "sync:bills": "node ../../.tools/with-env.mjs tsx src/scripts/sync-bills.ts",
    "sync:members": "node ../../.tools/with-env.mjs tsx src/scripts/sync-members.ts",
    "pretypecheck": "corepack pnpm --filter @civic-lens/types build && corepack pnpm --filter @civic-lens/utils build && corepack pnpm prisma:generate",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "node ../../.tools/with-env.mjs prisma generate",
    "prisma:migrate": "node ../../.tools/with-env.mjs prisma migrate dev",
    "prisma:migrate:deploy": "node ../../.tools/with-env.mjs prisma migrate deploy",
    "prisma:push": "node ../../.tools/with-env.mjs prisma db push"
  },
  "dependencies": {
    "@civic-lens/types": "workspace:*",
    "@civic-lens/utils": "workspace:*",
    "@nestjs/axios": "^4.0.0",
    "@nestjs/common": "^11.1.3",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.3",
    "@nestjs/platform-express": "^11.1.3",
    "@prisma/client": "^6.9.0",
    "axios": "^1.9.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "fast-xml-parser": "^4.5.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.7",
    "@types/express": "^5.0.3",
    "@types/node": "^22.15.30",
    "dotenv-cli": "^8.0.0",
    "prisma": "^6.9.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
